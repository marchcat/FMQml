+        result.httpStatus = reply->attribute(QNetworkRequest::HttpStatusCodeAttribute).toInt();
+        result.networkError = reply->error();
+        result.body = reply->readAll();
+        result.timedOut = timedOut;
+        result.oversize = oversize;
+        delete reply;
+        return result;
+    }
